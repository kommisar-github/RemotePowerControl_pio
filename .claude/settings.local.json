{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/mcp/task-router/start.sh ] && bash .claude/mcp/task-router/start.sh; true",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "if [ -n \"$TASK_ROUTER_AGENT\" ]; then curl -sf \"http://127.0.0.1:3100/memories?agent=$TASK_ROUTER_AGENT&project=$TASK_ROUTER_PROJECT&format=text\" 2>/dev/null; fi; true",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f memory/MEMORY.md ]; then echo '=== repo auto-memory (memory/MEMORY.md) ==='; cat memory/MEMORY.md; fi; true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TASK_ROUTER_AGENT\" ]; then curl -sf \"http://127.0.0.1:3100/hook/check?agent=$TASK_ROUTER_AGENT&project=$TASK_ROUTER_PROJECT\" 2>/dev/null; fi; true",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3100/hook/stop",
            "headers": {
              "X-Task-Router-Agent": "$TASK_ROUTER_AGENT",
              "X-Task-Router-Project": "$TASK_ROUTER_PROJECT"
            },
            "allowedEnvVars": [
              "TASK_ROUTER_AGENT",
              "TASK_ROUTER_PROJECT"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:3100/hook/stop",
            "headers": {
              "X-Task-Router-Agent": "$TASK_ROUTER_AGENT",
              "X-Task-Router-Project": "$TASK_ROUTER_PROJECT"
            },
            "allowedEnvVars": [
              "TASK_ROUTER_AGENT",
              "TASK_ROUTER_PROJECT"
            ],
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(//d/d/Cloud/OneDrive - Home Office/MyProjects/GitHub/**)",
      "Read(//d/d/Cloud/OneDrive - Home Office/MyProjects/GitHub/RemotePowerControl_pio/**)",
      "Bash(cp __TRACKED_VAR__/client.js .claude/mcp/task-router/)",
      "Bash(cp __TRACKED_VAR__/client.sh .claude/mcp/task-router/)",
      "Bash(cp __TRACKED_VAR__/client.cmd .claude/mcp/task-router/)",
      "Bash(cp __TRACKED_VAR__/start.sh .claude/mcp/task-router/)",
      "Bash(chmod +x .claude/mcp/task-router/client.sh .claude/mcp/task-router/start.sh)",
      "Read(//d/d/Cloud/OneDrive - Home Office/MyProjects/GitHub/RemotePowerControl_pio/.claude/skills/pm/**)",
      "Bash(grep -n \"=== /\\\\|=== end\\\\|=== main.cpp\\\\|=== end ownership\" src/main.cpp)"
    ]
  }
}
